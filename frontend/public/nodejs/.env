# 智谱 AI（https://open.bigmodel.cn）— 手机号注册即可，国内支付
# 聊天 + 拍照识别共用同一个 Key
LLM_API_KEY=7e9ba02834c44d19971b19a1edae42d2.gKqTUxTEgmIBxZWK
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 小膳青聊天（文本模型，速度快、价格低）
LLM_MODEL=glm-4-flash

# 拍照识别（视觉模型，glm-4v-flash 目前免费）
VISION_MODEL=glm-4v-flash

# 也可使用别名
# ZHIPU_API_KEY=你的智谱api-key

# 不配置 Key 时：聊天降级为规则引擎，拍照识别会报错

# 其他国内平台（取消注释并替换上方配置）：
# DeepSeek（仅文本，暂无官方视觉 API）  LLM_BASE_URL=https://api.deepseek.com/v1  LLM_MODEL=deepseek-chat
# 硅基流动  LLM_BASE_URL=https://api.siliconflow.cn/v1  LLM_MODEL=Qwen/Qwen2.5-7B-Instruct  VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# 本地 Ollama  LLM_BASE_URL=http://localhost:11434/v1  LLM_API_KEY=ollama